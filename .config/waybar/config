{
    "id": "bar-0",
    "layer": "top",
    "position": "top",
    "modules-left": [
        "clock",
        "clock#date",
        "custom/pacman"
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "custom/cava",
        "pulseaudio",
        "bluetooth",
        "network",
        "backlight",
        "battery",
        "custom/powermenu"
    ],
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "<span color='#00FF00'>ΎΝΔ</span>",
            "2": "<span color='#FFFFFF'>ΎΒΕ</span>",
            "3": "<span color='#FFFF00'>Όαθ</span>",
            "4": "<span color='#00FFFF'>ΎΚρ</span>",
            "5": "<span color='#A020F0'>ΎΖς</span>",
            "6": "<span color='#FF0000'>ΎΑΥ</span>",
            "default": "<span color='#0000FF'>ΎΖ║</span>"
        },
        "sort-by-number": true,
        "all-outputs": true,
        "on-click": "activate"
    },
    "clock": {
        "interval": 1,
        "timezone": "Asia/Shanghai",
        "locale": "zh_CN.UTF-8",
        "format": "<span color='#d3869b'>ΎβΠ </span>{:%H:%M:%S}",
        "tooltip": false
    },
    "clock#date": {
        "format": "<span color='#89b482'>ΎΒ│ </span>{:%A %m/%d}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='#5e81ac'><b>{}</b></span>",
                "days": "<span color='#88c0d0'><b>{}</b></span>",
                "weekdays": "<span color='#d08770'><b> {} </b></span>",
                "today": "<span color='#fb4934'><b><u>{}</u></b></span>"
            }
        }
    },
    "cpu": {
        "interval": 5,
        "format": "ΎΜδ {usage}%",
        "tooltip": false
    },
    "memory": {
        "interval": 5,
        "format": "ΎΣ▓ {}%",
        "tooltip-format": "ΎΣ▓ {used} GiB / {total} GiB"
    },
    "temperature": {
        "interval": 1,
        "format": "{icon} {temperatureC}┬░C",
        "format-icons": [
            "ΎΜΜ",
            "ΎΜΚ",
            "ΎΜΙ",
            "ΎΜΙ"
        ],
        "tooltip": false
    },
    "pulseaudio": {
        "format": "<span color='#d8a657'>{icon}</span> {volume}%",
        "format-muted": "ΎςΑ Muted",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΛΦ",
            "headset": "ΎΑξ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": [
                "ΎΑο",
                "ΎΑπ",
                "ΎΑρ"
            ]
        },
        "scroll-step": 5,
        "on-click": "pamixer --get-default-sink -t",
        "on-click-right": "pavucontrol"
    },
    "bluetooth": {
        "format-on": "<span color='#7daea3'>ΎΨψ </span>",
        "format-connected": "<span color='#00FF00'>ΎΨ│ </span>{device_alias}",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click": "blueman-manager",
        "on-click-right": "kitty -e bluetoothctl"
    },
    "network": {
        "format-ethernet": "<span color='#7daea3'>Ύδ┐</span> {ifname}",
        "tooltip-format-ethernet": "<span color='#7daea3'>Ύδ┐</span> {ifname} via {gwaddr}",
        "format-wifi": "<span color='#89b482'>{icon}</span> ",
        "tooltip-format-wifi": "{essid} via {ifname}, Strength: {signalStrength}%",
        "format-icons": [
            "≤░νυ",
            "≤░νν",
            "≤░νπ",
            "≤░νς"
        ],
        "format-disconnected": "<span color='#ea6962'>Ύια </span>Disconnected",
        "on-click": "~/.scripts/wifi-menu.sh"
    },
    "backlight": {
        "format": "<span color='#d8a657'>{icon}</span> {percent}%",
        "format-icons": [
            "ΎΩβ",
            "ΎΩγ",
            "ΎΩδ",
            "ΎΩε",
            "ΎΩη",
            "ΎΩθ"
        ],
        "tooltip": false
    },
    "battery": {
        "bat": "BAT0",
        "states": {
            "good": 90,
            "warning": 30,
            "critical": 15
        },
        "format": "<span color='#a9b665'>{icon}</span> {capacity}%",
        "format-charging": "ΎΘο {icon} {capacity}%",
        "format-plugged": "ΎΘο {capacity}%",
        "format-icons": [
            "ΎΚΕ",
            "ΎΚΔ",
            "ΎΚΓ",
            "ΎΚΒ",
            "ΎΚΑ"
        ],
        "tooltip": true,
        "tooltip-format": "{timeTo} {power}w"
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{icon} {name}",
        "format-icons": {
            "locked": "ΎΑμ",
            "unlocked": "ΎΓε"
        }
    },
    "custom/cava": {
        "format": "{}",
        "exec": "$HOME/.scripts/cava.sh",
        "tooltip": false
    },
    "custom/logo": {
        "format": " {} ΎΝΔ",
        "tooltip": false
    },
    "custom/pacman": {
        "interval": 360,
        "format": "<span color='#a9b665'>Ύηθ</span> {}",
        "exec": "checkupdates | wc -l",
        "exex-if": "checkupdates",
        "on-click": "kitty -e yay -Syu && pkill -SIGRTMIN+8 waybar",
        "signal": 8,
        "tooltip": false
    },
    "custom/powermenu": {
        "format": "ΎΑΣ {}",
        "on-click": "$HOME/.scripts/powermenu.sh",
        "tooltip": false
    }
}
